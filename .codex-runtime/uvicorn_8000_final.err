2026-06-14 11:01:32,396 - apps.chat.task.llm - INFO:1401 - used_tables_schema: 
【DB_ID】 public
【Schema】
# Table: public.dim_player, 玩家维表，记录注册归因、设备、区服、活跃分层、付费分层和当前状态。
[
(player_id:integer, 玩家ID，主键。),
(account_id:text, 账号ID，模拟真实账号唯一标识。),
(register_time:timestamp with time zone, 角色注册时间。),
(install_date:date, 安装日期，也作为新增用户日期。),
(country:text, 国家或地区。),
(language:text, 客户端或玩家语言。),
(platform:text, 平台：android、ios或pc_emulator。),
(channel:text, 获客渠道，如organic、google_ads、tiktok_ads。),
(campaign:text, 广告计划或活动名称。),
(device_tier:text, 设备档位：low、mid、high、ultra。),
(register_server_id:integer, 注册区服ID。),
(activity_segment:text, 活跃倾向分层：casual、regular、engaged、social、hardcore。),
(payer_segment:text, 付费倾向分层：non_spender、minnow、dolphin、whale。),
(current_level:integer, 当前玩家等级。),
(current_vip_level:integer, 当前VIP等级。),
(current_power:bigint, 当前战力。),
(current_city_level:integer, 当前主城等级。),
(current_alliance_id:integer, 当前所在联盟ID，未入盟为空。),
(first_pay_time:timestamp with time zone, 首次付费时间，未付费为空。),
(total_pay_amount:numeric(12,2), 累计付费金额，美元。),
(last_active_date:date, 最后活跃日期。)
]
# Table: public.fact_payments, 支付订单事实表，一行代表一笔成功支付订单。
[
(order_id:text, 订单ID，主键。),
(event_time:timestamp with time zone, 支付成功时间。),
(event_date:date, 支付成功日期。),
(player_id:integer, 付费玩家ID。),
(server_id:integer, 区服ID。),
(session_id:bigint, 支付发生的会话ID。),
(product_id:text, 商品ID。),
(product_name:text, 商品中文名。),
(amount_usd:numeric(10,2), 订单金额，美元。),
(local_currency:text, 本地币种，如CNY或USD。),
(payment_channel:text, 支付渠道，如app_store、google_play、third_party、web_pay。),
(is_first_pay:boolean, 是否玩家首笔付费。),
(pay_sequence:integer, 玩家第几笔付费。),
(lifecycle_day:integer, 付费时玩家生命周期天数。),
(vip_level_after:integer, 支付后VIP等级。),
(player_level:integer, 支付时玩家等级。),
(revenue_tier:text, 订单金额层级：low、mid、whale。),
(attributes:jsonb, 订单扩展属性JSON，例如广告计划和付费分层。)
]

